{
  "compilerOptions": {
    "outDir": "../dist",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Node",
    "target": "ES2022",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "baseUrl": ".",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["**/*.ts", "shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
